@model EmployeeManagementMVC.Models.Employee

<div asp-validation-summary="All" class="text-danger"></div>
<h2>Add Employee</h2>

<form asp-action="Create" method="post">

    <div>
        <label>Employee Name</label>
        <input asp-for="EmployeeName" class="form-control" />
        <span asp-validation-for="EmployeeName" class="text-danger"></span>
    </div>

    <br />
    
        <div class="mb-3">
            <label asp-for="DepartmentId" class="form-label"></label>

            <select asp-for="DepartmentId"
                    asp-items="ViewBag.Department"
                    class="form-select">

                <option value="">-- Select Department --</option>

            </select>

            <span asp-validation-for="DepartmentId"
                  class="text-danger"></span>
        </div>
    
    <span asp-validation-for="EmployeeName" class="text-danger"></span>
    <br />
@* 
    <div>
        <label>Department</label>
        <input asp-for="Department" />
    </div> *@
    @* <span asp-validation-for="Department" class="text-danger"></span>
    <br /> *@

    <div>
        <label>Salary</label>
        <input asp-for="Salary" />
    </div>
    <span asp-validation-for="Salary" class="text-danger"></span>
    <br />

    <button type="submit" class="btn btn-primary">
        Save
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Back
    </a>
    
</form>