@model EmployeeManagementMVC.Models.Employee

<!DOCTYPE html>
<html>
<head>
    <title>Employee Details</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

    <div class="container mt-5">

        <div class="card">

            <div class="card-header bg-info text-white">
                <h3>Employee Details</h3>
            </div>

            <div class="card-body">

                <p><strong>Employee Id :</strong> @Model.EmployeeId</p>

                <p><strong>Name :</strong> @Model.EmployeeName</p>

                <p><strong>Department :</strong> @Model.Department</p>

                <p><strong>Salary :</strong> ₹ @Model.Salary</p>

            </div>

        </div>

        <br />

        <a asp-action="Index" class="btn btn-secondary">
            Back
        </a>

    </div>

</body>
</html>